#!/bin/bash

# ==========================================================
# AdIt - AI assistant for the lab
# ==========================================================

INSTALL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SERVER_URL="http://127.0.0.1:8000"

# Auto-detect aider/uvicorn
AIDER=$(which aider)
UVICORN=$(which uvicorn)

if [ -z "$AIDER" ]; then
    echo "[AdIt] ERROR: aider not found. Please install it:"
    echo "  pip install aider-chat"
    exit 1
fi

if [ -z "$UVICORN" ]; then
    echo "[AdIt] ERROR: uvicorn not found. Please install it:"
    echo "  pip install uvicorn"
    exit 1
fi

# Check if server is already running
if ! curl -s "$SERVER_URL/v1/models" > /dev/null 2>&1; then
    echo "[AdIt] Starting RAG server (this may take ~30 seconds)..."
    cd "$INSTALL_DIR"
    "$UVICORN" app.server:app \
        --port 8000 \
        --workers 1 \
        > /tmp/AdIt_server.log 2>&1 &

    # Wait for server to be ready (max 60 seconds)
    for i in $(seq 1 60); do
        if curl -s "$SERVER_URL/v1/models" > /dev/null 2>&1; then
            echo "[AdIt] Server ready."
            break
        fi
        sleep 1
        if [ "$i" -eq 60 ]; then
            echo "[AdIt] ERROR: Server failed to start. Check /tmp/AdIt_server.log"
            exit 1
        fi
    done
else
    echo "[AdIt] Server already running."
fi

# Launch Aider
cd "$INSTALL_DIR"
"$AIDER" \
    --openai-api-base "$SERVER_URL/v1" \
    --openai-api-key dummy \
    --model gpt-4o-mini \
    --no-auto-commits \
    --chat-mode ask
